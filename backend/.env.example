PORT=3001
DATABASE_URL=postgresql://postgres:SUASENHA@db.xxxxxxxxxxxx.supabase.co:5432/postgres
JWT_SECRET=troque_por_um_segredo_forte

# Opcional: roda contra um schema Postgres diferente do padrão (public).
# Usado no ambiente de staging (PG_SCHEMA=zync_staging) — ver database/README.md.
# PG_SCHEMA=zync_staging

# URL pública deste backend (usada pro SyncPay chamar de volta o webhook)
BACKEND_PUBLIC_URL=http://localhost:3001

# URL do frontend (usada pra montar o link de redefinição de senha)
FRONTEND_URL=http://localhost:5500

# Credenciais da conta SyncPay (pegar no painel do SyncPay)
SYNCPAY_BASE_URL=
SYNCPAY_CLIENT_ID=
SYNCPAY_CLIENT_SECRET=
SYNCPAY_WEBHOOK_TOKEN=

# Token compartilhado pra autenticar o webhook do WhatsApp (header Authorization: Bearer <token>)
WHATSAPP_WEBHOOK_TOKEN=

# DSN do Sentry (sentry.io) pra captura de erros/exceções em produção.
# Sem essa variável, a captura fica desativada (ex: localmente, nos testes).
SENTRY_DSN=

# Envio de e-mail real via SendGrid (sendgrid.com). EMAIL_FROM precisa ser
# o e-mail verificado em Settings > Sender Authentication > Single Sender.
# Sem SENDGRID_API_KEY, o envio cai no mock (console.log) — ex: localmente, nos testes.
SENDGRID_API_KEY=
EMAIL_FROM=

# Notificação push (ntfy.sh) em eventos-chave (cadastro, login, pagamento).
# Sem dado pessoal na mensagem — só o nome do tópico já funciona como "senha"
# fraca, então não reusar esse valor pra nada sensível. Sem essa variável,
# a notificação não é enviada (padrão em dev/teste).
NTFY_TOPIC=
